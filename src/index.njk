  <section class="section-pad border-top" id="about">
    <div class="container split-section">
      <div class="section-heading reveal">
        <p class="eyebrow">About</p>
        <h2>Engineering is where ideas meet wiring, tolerances, and inconvenient reality.</h2>
      </div>
      <div class="content-stack reveal">
        <p>My work sits at the intersection of mechanical design, embedded firmware, controls, and pneumatic actuation. I enjoy building systems that move, sense, respond, and provide measurable feedback rather than remaining as clean diagrams on paper.</p>
        <p>I value clear documentation, practical testing, and honest limitations. A design that works only in a slide deck is decoration; a design that survives troubleshooting earns respect.</p>
        <div class="signal-row" aria-label="Research interests">
          <span>Soft robotic actuation</span>
          <span>Tele-rehabilitation</span>
          <span>Embedded control</span>
          <span>Sensor feedback &amp; instrumentation</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad border-top" id="projects">
    <div class="container">
      <div class="section-heading wide reveal">
        <p class="eyebrow">Selected Engineering Projects</p>
        <h2>A few representative builds — hardware, firmware, CAD, testing, and documentation.</h2>
      </div>

      <div class="project-grid">
        {%- for p in collections.projects %}
        {%- if p.data.highlight %}
        <article class="project-card reveal{{ ' featured' if p.data.featured }}" data-domain="{{ p.data.domain }}">
          <div class="project-visual">
            {%- if p.data.thumbnail %}
            {% image p.data.thumbnail, (p.data.cardTitle or p.data.caseTitle or p.data.title), "(min-width: 760px) 540px, 100vw" %}
            {%- else %}
            <span class="chip-icon" aria-hidden="true">{{ p.data.chip or "ESP32" }}</span>
            {%- endif %}
          </div>
          <div class="card-content">
            <p class="project-kicker">{{ p.data.kicker }}</p>
            <h3>{{ p.data.cardTitle or p.data.caseTitle or p.data.title }}</h3>
            <p>{{ p.data.summary }}</p>
            {%- set ctags = p.data.cardTags or p.data.tags %}
            {%- if ctags %}<div class="tag-row">{% for t in ctags %}{% if loop.index <= 5 %}<span>{{ t }}</span>{% endif %}{% endfor %}</div>{% endif %}
            {%- if (p.data.hasCaseStudy and p.url) or p.data.repo %}
            <div class="card-actions">
              {%- if p.data.hasCaseStudy and p.url %}<a class="card-link" href="{{ p.url }}">Read case study →</a>{% endif %}
              {%- if p.data.repo %}<a href="{{ p.data.repo }}" target="_blank" rel="noopener">Repository<span aria-hidden="true" class="external-icon"> ↗</span><span class="sr-only"> (opens in a new tab)</span></a>{% endif %}
            </div>
            {%- endif %}
          </div>
        </article>
        {%- endif %}
        {%- endfor %}
      </div>

      <div class="hero-actions">
        <a class="button button-primary" href="/projects/">View all projects →</a>
      </div>
    </div>
  </section>

