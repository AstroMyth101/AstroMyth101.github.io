---
layout: base.njk
schemaType: CreativeWork
---
<main id="main">
  <section class="case-hero">
    <div class="container case-grid">
      <div class="reveal">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">/</span>
          <a href="/projects/">Projects</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{{ cardTitle or caseTitle or title }}</span>
        </nav>
        {%- if kicker %}<p class="eyebrow">{{ kicker }}</p>{% endif %}
        <h1>{{ caseTitle or title }}</h1>
        {%- if lede %}<p class="hero-lede">{{ lede }}</p>{% endif %}
        {%- if tags %}
        <div class="tag-row">{% for t in tags %}<span>{{ t }}</span>{% endfor %}</div>
        {%- endif %}
        {%- if actions %}
        <div class="hero-actions">
          {%- for a in actions %}
          <a class="button {{ 'button-primary' if loop.first else 'button-secondary' }}" href="{{ a.url }}"{% if a.external %} target="_blank" rel="noopener"{% endif %}>{{ a.label }}</a>
          {%- endfor %}
        </div>
        {%- endif %}
      </div>

      {%- if facts %}
      <aside class="case-panel reveal" aria-label="Project facts">
        <dl>
          {%- for f in facts %}
          <div>
            <dt>{{ f.term }}</dt>
            <dd>{{ f.detail }}</dd>
          </div>
          {%- endfor %}
        </dl>
      </aside>
      {%- endif %}
    </div>
  </section>

  <section class="section-pad border-top">
    <div class="container case-content">
      {%- for s in sections %}
      <article class="case-section reveal">
        {%- if s.eyebrow %}<p class="eyebrow">{{ s.eyebrow }}</p>{% endif %}
        {%- if s.heading %}<h2>{{ s.heading }}</h2>{% endif %}
        {%- if s.body %}{{ s.body | markdown | safe }}{% endif %}
        {%- if s.image %}
        <figure class="case-figure">
          {% image s.image, s.imageAlt %}
          {%- if s.caption %}<figcaption>{{ s.caption }}</figcaption>{% endif %}
        </figure>
        {%- endif %}
      </article>
      {%- endfor %}
      {{ content | safe }}
    </div>
  </section>
</main>
